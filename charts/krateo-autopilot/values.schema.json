{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "krateo-autopilot values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "namespace": {
      "type": "string"
    },
    "geminiApiKey": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "secretName": {
          "type": "string"
        },
        "secretKey": {
          "type": "string"
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        }
      }
    },
    "vertexAI": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "projectID": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "secretName": {
          "type": "string"
        }
      }
    },
    "mcpServers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "url": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "modelConfig": {
            "type": "string"
          },
          "skillRef": {
            "type": "string"
          }
        }
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string"
        }
      }
    }
  }
}
