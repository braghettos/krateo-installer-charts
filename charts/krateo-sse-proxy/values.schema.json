{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "krateo-sse-proxy values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true
    },
    "replicaCount": {
      "type": "integer"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "clickhouse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "passwordSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "key": {
              "type": "string"
            },
            "optional": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "listenAddr": {
      "type": "string"
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": true
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": true
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
